#!/usr/bin/env python3
"""
generate_prompt.py v1_1_0 — 一行命令生成AI提示词。

读取 STRATEGY.md 模板，替换 {{CHAPTER}} 占位符，输出完整的AI提示词。

用法：
    # 输出到 stdout（可管道给 AI）
    python AI_reader/generate_prompt.py --chapter 10

    # 输出到文件
    python AI_reader/generate_prompt.py --chapter 10 --output /tmp/prompt.txt

输出：完整AI提示词文本（STRATEGY.md中{{CHAPTER}}已替换为目标章节）。
"""

import argparse
import sys
from pathlib import Path


def resolve_prompt(chapter: int, template_path: Path) -> str:
    """读取模板文件，替换 {{CHAPTER}} 占位符，返回完整提示词。

    Args:
        chapter: 目标 LLPSI 章节号（1-34）
        template_path: PROMPT.md 模板文件路径

    Returns:
        替换后的完整提示词文本

    Raises:
        FileNotFoundError: 模板文件不存在
        ValueError: 章节号超出有效范围
    """
    if not 1 <= chapter <= 34:
        raise ValueError(
            f"章节号必须在 1-34 之间（LLPSI 共 34 章），当前输入: {chapter}。"
        )

    if not template_path.exists():
        raise FileNotFoundError(
            f"模板文件不存在: {template_path}\n"
            f"请确保 PROMPT.md 与 generate_prompt.py 在同一目录，"
            f"或通过 --template 指定路径。"
        )

    raw = template_path.read_text(encoding="utf-8")
    return raw.replace("{{CHAPTER}}", str(chapter))


def main() -> None:
    parser = argparse.ArgumentParser(
        description="生成 LLPSI 扩展读物 AI 提示词（替换 {{CHAPTER}} 占位符）。"
    )
    parser.add_argument(
        "--chapter", "-c",
        type=int, required=True, metavar="N",
        help="目标 LLPSI 章节号（1-34）"
    )
    parser.add_argument(
        "--output", "-o",
        type=Path, default=None,
        help="输出文件路径。不指定则输出到 stdout。"
    )
    parser.add_argument(
        "--template", "-t",
        type=Path,
        default=Path(__file__).resolve().parent / "STRATEGY.md",
        help="模板路径（默认：脚本同目录下的 STRATEGY.md）"
    )
    args = parser.parse_args()

    # 解析提示词
    prompt = resolve_prompt(args.chapter, args.template)

    # 输出
    if args.output:
        args.output.write_text(prompt, encoding="utf-8")
        print(f"[generate_prompt] 提示词已写入: {args.output}  (章节=Cap.{args.chapter})",
              file=sys.stderr)
    else:
        sys.stdout.write(prompt)


if __name__ == "__main__":
    main()
